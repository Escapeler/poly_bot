# ══════════════════════════════════════════════════════════
# Polymarket Copy Trade Bot — Configuration
# ══════════════════════════════════════════════════════════

# ── Wallet ────────────────────────────────────────────────
WALLET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS
FUNDER_ADDRESS=0xYOUR_PROXY_WALLET

# Signature type: 0=EOA, 1=proxy, 2=Safe
SIGNATURE_TYPE=0

# ── Polymarket API Credentials (L2) ──────────────────────
# AUTO-DERIVED: Leave these EMPTY. Bot will derive them automatically
# from your WALLET_PRIVATE_KEY on first startup and save them here.
# Only fill manually if auto-derive fails.
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# ── Copy Trade Targets ───────────────────────────────────
# Comma-separated wallet addresses to copy
TARGET_WALLETS=0x123,0x456

# ── Trade Settings ───────────────────────────────────────
SIZE_MULTIPLIER=1.0
MAX_POSITION_USDC=5
SLIPPAGE_TOLERANCE=0.02
COPY_RATIO=1
DEFAULT_ORDER_TYPE=FOK
RETRY_MAX_ATTEMPTS=3
RETRY_DELAY_MS=100
MAX_SIGNAL_AGE_SEC=120

# ── 5-min Crypto Market Settings ─────────────────────────
# These markets have 10% fee (1000bps) and expire every 5 minutes.
# Set to "false" to skip all 5-min crypto markets entirely.
# Recommended: only enable if target wallet has proven 55%+ win rate on 5-min.
ENABLE_5MIN_MARKETS=true
# Max position for 5-min markets (separate from regular markets)
MAX_POSITION_5MIN_USDC=3

# ── Anti-Double Order Tuning ─────────────────────────────
# Layer 1 (txHash dedup) is always on, cannot be configured.
# Below settings control layers 2-4. Lower = faster, higher = safer.
#
# Layer 2: Atomic lock duration (ms). Prevents WS+REST race.
# Must be >= REST poll interval (2000ms). Default: 2000
PROCESSING_LOCK_MS=2000
#
# Layer 3: Debounce per token for BUY (ms). SELL is never debounced.
# How long to ignore rapid BUY signals for same token. Default: 500
DEBOUNCE_MS=500
#
# Layer 4: BUY cooldown per market (seconds). SELL has no cooldown.
# Minimum gap between BUY orders on same market. Default: 2
BUY_COOLDOWN_SEC=2

# ── Auto Redeem ──────────────────────────────────────────
AUTO_REDEEM_ENABLED=true
REDEEM_CHECK_INTERVAL_SEC=60

# ── Kill Switch ──────────────────────────────────────────
MAX_DAILY_LOSS_USDC=200
MAX_OPEN_POSITIONS=20
KILL_SWITCH_ENABLED=true

# ── RPC / Endpoints ─────────────────────────────────────
RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_WS_URL=
INFURA_API_KEY=
POLYGON_RPC_FALLBACK_1=https://polygon-rpc.com
POLYGON_RPC_FALLBACK_2=https://rpc.ankr.com/polygon
POLYGON_RPC_FALLBACK_3=https://polygon.llamarpc.com

# ── Polymarket URLs ──────────────────────────────────────
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_URL=https://data-api.polymarket.com

# ── Almanac ──────────────────────────────────────────────
ALMANAC_BASE_URL=https://api.almanac.market/api

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=info

# ── Healthcheck ──────────────────────────────────────────
HEALTH_PORT=8081
